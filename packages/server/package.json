{
  "name": "@necro-crown/server",
  "author": "Weston Vincze",
  "description": "NecroCrown Colyseus Server",
  "private": true,
  "version": "0.0.1",
  "main": "build/index.js",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">= 16.13.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && tsc",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**_test.ts --exit --timeout 15000"
  },
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/testing": "^0.17.10",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "mocha": "^11.7.5",
    "rimraf": "^5.0.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@colyseus/tools": "^0.17.0",
    "@necro-crown/shared": "workspace:*",
    "@colyseus/schema": "^4.0.0",
    "colyseus": "^0.17.6",
    "express": "^4.18.2",
    "bitecs": "^0.4.0",
    "pathfinding": "github:WestonVincze/PathFinding.js",
    "typescript": "^5.9.3"
  }
}